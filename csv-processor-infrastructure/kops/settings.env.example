# Copy to settings.env and fill in before running scripts/bootstrap.sh or scripts/teardown.sh
# cp settings.env.example settings.env

export AWS_REGION=us-east-1
export AWS_ACCOUNT_ID=<YOUR_AWS_ACCOUNT_ID>

export CLUSTER_NAME=csv-processor.k8s.local
export KOPS_STATE_BUCKET=csv-processor-kops-state-${AWS_ACCOUNT_ID}
export IRSA_DISCOVERY_BUCKET=csv-processor-irsa-discovery-${AWS_ACCOUNT_ID}
export PROCESSED_BUCKET=csv-processor-processed-${AWS_ACCOUNT_ID}

# S3 lifecycle: days before transitioning processed/ objects to cheaper storage
export GLACIER_TRANSITION_DAYS=30
export GLACIER_DEEP_ARCHIVE_DAYS=180

# Helm app namespace + release name must match IRSA service account in cluster-config.yaml
export APP_NAMESPACE=csv-processor
export APP_RELEASE=csv-processor

# kops IRSA role name pattern: {sa}.{namespace}.sa.{cluster}
export APP_IRSA_ROLE_NAME=${APP_RELEASE}.${APP_NAMESPACE}.sa.${CLUSTER_NAME}
